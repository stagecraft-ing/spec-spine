# Enforce LF line endings for all text files in this repository.
# This prevents "LF will be replaced by CRLF" warnings on Windows
# and ensures consistent line endings across all platforms.

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# --- Source code ---
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.vue       text eol=lf

# --- Config / markup ---
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf

# --- Docs ---
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf

# --- Shell / config ---
*.sh        text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
.env*       text eol=lf
Dockerfile* text eol=lf
*.dockerfile text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.eslintrc*  text eol=lf
.prettierrc* text eol=lf

# --- Binary: never touch line endings ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary

# --- Derived-artifact merge driver (spec 020, narrowed by spec 024) ---
# Since spec 024 the committed artifacts are sharded per authority unit, so two
# PRs that touch DIFFERENT specs/packages write disjoint files and never
# conflict (the driver is no longer needed for that common case). It remains
# registered on the shard globs for the RARE same-shard conflict (two PRs that
# both edit the same spec/package): the `spec-spine-derived-regen` driver
# regenerates the shard tree from the merged working tree instead of leaving
# conflict markers. Opt-in: register the driver per-clone with
# `./.githooks/enable-merge-driver.sh` (see CLAUDE.md). If unregistered, git
# falls back to the default text merge; no behavior change.
.derived/spec-registry/by-spec/*.json merge=spec-spine-derived-regen
.derived/codebase-index/by-spec/*.json merge=spec-spine-derived-regen
.derived/codebase-index/by-package/*.json merge=spec-spine-derived-regen
.derived/codebase-index/slices.json merge=spec-spine-derived-regen
